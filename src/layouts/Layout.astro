---
import '../styles/global.css';
import Hyperspeed from '../components/Hyperspeed.jsx';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	canonicalUrl?: string;
	ogImage?: string;
}

const {
	title = "Grammarly AI Humanizer | Free & Undetectable AI Humanizer Tool",
	description = "Bypass GPTZero, Turnitin, and ZeroGPT with Grammarly AI Humanizer. The best free AI humanizer tool to convert AI text into natural, undetectable human-written content.",
	keywords = "Ai Humanizer, ai humanizer, ai humanizer free, clever ai humanizer, free ai humanizer, walter writes ai humanizer, best ai humanizer, grammarly ai humanizer, ai humanizer tool, undetectable ai humanizer, ai humanizer text, free ai humanizer tool, best ai humanizer free, ai humanizer grammarly",
	canonicalUrl = "https://grammarlyaihumanizer.com/",
	ogImage = "https://grammarlyaihumanizer.com/og-image.png"
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<!-- Google tag (gtag.js) -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XQYV2GT2R2"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-XQYV2GT2R2');
		</script>

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Optimization -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="author" content="Grammarly AI Humanizer" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="sitemap" href="/sitemap.xml" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content="Grammarly AI Humanizer" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={ogImage} />

		<!-- Typography Imports -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono&display=swap" rel="stylesheet">
		
		<!-- Force Dark Mode -->
		<script is:inline>
			document.documentElement.classList.add('dark');
		</script>
	</head>
	<body class="text-ink min-h-screen flex flex-col font-sans transition-colors duration-200">
		<!-- Hyperspeed Full-Screen Background -->
		<div class="aurora-bg-wrapper">
			<Hyperspeed
				client:only="react"
				effectOptions={{
					distortion: 'turbulentDistortion',
					length: 400,
					roadWidth: 10,
					islandWidth: 2,
					lanesPerRoad: 4,
					fov: 90,
					fovSpeedUp: 150,
					speedUp: 2,
					carLightsFade: 0.4,
					totalSideLightSticks: 20,
					lightPairsPerRoadWay: 40,
					shoulderLinesWidthPercentage: 0.05,
					brokenLinesWidthPercentage: 0.1,
					brokenLinesLengthPercentage: 0.5,
					lightStickWidth: [0.12, 0.5],
					lightStickHeight: [1.3, 1.7],
					movingAwaySpeed: [60, 80],
					movingCloserSpeed: [-120, -160],
					carLightsLength: [400 * 0.03, 400 * 0.2],
					carLightsRadius: [0.05, 0.14],
					carWidthPercentage: [0.3, 0.5],
					carShiftX: [-0.8, 0.8],
					carFloorSeparation: [0, 5],
					colors: {
						roadColor: 0x080808,
						islandColor: 0x0a0a0a,
						background: 0x000000,
						shoulderLines: 0xffffff,
						brokenLines: 0xffffff,
						leftCars: [0xd856bf, 0x6750a2, 0xc247ac],
						rightCars: [0x03b3c3, 0x0e5ea5, 0x324555],
						sticks: 0x03b3c3,
					}
				}}
			/>
		</div>

		<div class="flex-grow flex flex-col animate-fade-up" style="position:relative;z-index:1;">
			<slot />
		</div>

		<script>
			// Intersection Observer for scroll-triggered premium reveals
			function initScrollReveal() {
				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target); // Stop observing once it's revealed
						}
					});
				}, {
					threshold: 0.05,
					rootMargin: '0px 0px -30px 0px'
				});

				const targets = document.querySelectorAll('.reveal-on-scroll');
				targets.forEach((target) => observer.observe(target));
			}

			// Initialize on load
			window.addEventListener('DOMContentLoaded', initScrollReveal);
			
			// Re-run observer initialization if view transitions or content dynamic swaps occur
			document.addEventListener('astro:after-swap', initScrollReveal);
		</script>
	</body>
</html>

