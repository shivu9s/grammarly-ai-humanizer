  function getDailyHumanizationCount(): number {
    try {
      const stored = localStorage.getItem('humanize_timestamps');
      const timestamps = stored ? JSON.parse(stored) : [];
      const now = Date.now();
      const oneDayAgo = now - 24 * 60 * 60 * 1000;
      
      const active = timestamps.filter((t: number) => t > oneDayAgo);
      if (active.length !== timestamps.length) {
        localStorage.setItem('humanize_timestamps', JSON.stringify(active));
      }
      return active.length;
    } catch (e) {
      return 0;
    }
  }

