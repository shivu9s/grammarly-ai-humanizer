---
// HumanizerConsole.astro
import ElectricBorder from './ElectricBorder.jsx';
---

<section id="console" class="relative w-full py-8 sm:py-16 bg-transparent border-b border-hairline transition-colors duration-200 reveal-on-scroll">
  <div class="mx-auto max-w-7xl px-3 sm:px-6 lg:px-8">
    
    <!-- Workspace Title -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-6 border-b border-hairline pb-4">
      <h2 class="text-lg font-semibold text-ink flex items-center gap-2">
        <span class="flex h-2 w-2 rounded-full bg-primary"></span>
        AI Humanizer
      </h2>
      
      <!-- History Log Toggle -->
      <button id="toggle-history-btn" class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-body hover:text-ink bg-canvas hover:bg-canvas-soft-2 border border-hairline rounded-md transition-all hover:scale-[1.02] cursor-pointer">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        History
      </button>
    </div>

    <!-- Main Workspace Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      
      <!-- Left controls & inputs (lg:col-span-8 / lg:col-span-7 depending on mode) -->
      <div class="lg:col-span-7 space-y-6">
        
        <!-- Input Card -->
        <ElectricBorder
          client:only="react"
          color="#5227FF"
          speed={0.8}
          chaos={0.06}
          borderRadius={12}
          className="w-full card-marketing glass-input-premium p-6! relative"
          style={{ border: 'none', boxShadow: 'none' }}
        >
          <div id="input-card-container" class="w-full h-full flex flex-col bg-transparent">
            
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-sm font-mono uppercase tracking-wider text-mute">Input AI Text</h3>
              
              <!-- Paste & Upload Actions -->
              <div class="flex items-center gap-2">
                <button id="action-paste" class="flex items-center gap-1 px-2.5 py-1 text-xs text-body hover:text-ink hover:bg-canvas-soft-2 rounded border border-hairline transition-all hover:scale-[1.02] cursor-pointer" title="Paste from clipboard">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                  </svg>
                  Paste
                </button>
                <label for="file-upload" class="flex items-center gap-1 px-2.5 py-1 text-xs text-body hover:text-ink hover:bg-canvas-soft-2 rounded border border-hairline transition-all hover:scale-[1.02] cursor-pointer" title="Upload document">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                  </svg>
                  Upload
                </label>
                <input id="file-upload" type="file" accept=".txt" class="hidden" />
                <button id="action-clear" class="p-1 text-body hover:text-error hover:bg-canvas-soft-2 rounded transition-all hover:scale-[1.05] cursor-pointer" title="Clear text">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                </button>
              </div>
            </div>

            <!-- Text Area -->
            <div class="relative">
              <textarea id="workspace-input" placeholder="Paste your AI-generated text here (up to 500 words)..." class="w-full h-48 sm:h-80 bg-transparent text-ink border-0 focus:ring-0 focus:outline-none resize-none text-sm font-sans placeholder-mute leading-relaxed"></textarea>
            </div>

            <!-- Input Footer Info -->
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between border-t border-hairline pt-3 mt-2 text-xs text-mute font-mono gap-2">
              <div class="flex items-center gap-3">
                <span>Words: <strong id="input-word-count" class="text-ink">0</strong></span>
                <span>Characters: <strong id="input-char-count" class="text-ink">0</strong></span>
              </div>
              <span id="word-limit-indicator" class="transition-colors">Max: 500 words</span>
            </div>
          </div>
        </ElectricBorder>





        <!-- Action Button -->
        <div class="flex flex-col sm:flex-row justify-end gap-3 sm:gap-4">

          <button id="action-humanize" class="button-primary h-11 text-sm font-semibold flex items-center justify-center gap-2 cursor-pointer w-full sm:w-auto shimmer-btn hover:scale-[1.02]">
            <svg class="h-4 w-4 animate-spin text-cyan" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m0-12.728l.707.707m11.314 11.314l.707-.707M12 5a7 7 0 100 14 7 7 0 000-14z"/>
            </svg>
            Humanize Text
          </button>
        </div>

      </div>

      <!-- Right Result Displays (lg:col-span-5 / lg:col-span-5) -->
      <div class="lg:col-span-5 space-y-6">
        
        <!-- Processing State Card (Hidden by default) -->
        <div id="processing-card" class="hidden card-marketing processing-pulse p-8! text-center space-y-6 bg-canvas">
          <div class="flex justify-center">
            <div class="relative flex items-center justify-center h-16 w-16">
              <div class="animate-spin rounded-full h-16 w-16 border-b-2 border-primary"></div>
              <svg class="absolute h-6 w-6 text-primary animate-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
          </div>
          
          <div class="space-y-2">
            <h4 class="text-base font-semibold text-ink">Linguistic Rewriting in Progress</h4>
            <p class="text-sm text-body max-w-xs mx-auto">Varying sentence spacing, altering structures, and swapping robotic patterns...</p>
          </div>
          
          <!-- Steps indicators -->
          <div class="border-t border-hairline pt-4 space-y-2 text-left text-xs font-mono max-w-xs mx-auto">
            <div id="step-1" class="flex items-center gap-2 text-body">
              <div class="h-2 w-2 rounded-full bg-primary animate-ping"></div>
              <span>1. Parsing syntactic perplexity...</span>
            </div>
            <div id="step-2" class="flex items-center gap-2 text-mute">
              <div class="h-2 w-2 rounded-full bg-hairline"></div>
              <span>2. Recalculating structural burstiness...</span>
            </div>
            <div id="step-3" class="flex items-center gap-2 text-mute">
              <div class="h-2 w-2 rounded-full bg-hairline"></div>
              <span>3. Restructuring passive voice...</span>
            </div>
            <div id="step-4" class="flex items-center gap-2 text-mute">
              <div class="h-2 w-2 rounded-full bg-hairline"></div>
              <span>4. Final polishing & tone adjustment...</span>
            </div>
          </div>
        </div>

        <!-- Empty State Card -->
        <div id="empty-state-card" class="card-marketing p-12! text-center bg-canvas h-full min-h-[350px] flex flex-col justify-center items-center">
          <div class="p-4 rounded-full bg-canvas-soft-2 border border-hairline text-mute mb-6">
            <svg class="h-10 w-10 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364.364l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h4 class="text-base font-semibold text-ink mb-2">Awaiting Text Input</h4>
          <p class="text-sm text-body max-w-xs mx-auto leading-relaxed">
            Enter your AI-generated text on the left and select your parameters. Click "Humanize Text" to view metrics and comparisons.
          </p>
        </div>

        <!-- Output Dashboard & Metrics Card (Hidden initially) -->
        <div id="results-card" class="hidden space-y-6">
          


          <!-- Humanized Output Display Card -->
          <ElectricBorder
            client:only="react"
            color="#7cff67"
            speed={1.2}
            chaos={0.08}
            borderRadius={12}
            className="w-full card-marketing p-6! bg-canvas relative"
            style={{ border: 'none', boxShadow: 'none' }}
          >
            <div class="w-full h-full flex flex-col bg-transparent">
              <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-3 border-b border-hairline pb-3 gap-2">
                <h3 class="text-sm font-mono uppercase tracking-wider text-mute">Humanized Output</h3>
                
                <!-- Toggle highlights buttons -->
                <div class="flex items-center gap-1.5 bg-canvas-soft-2 rounded border border-hairline p-0.5">
                  <button id="toggle-diff" class="px-2.5 py-1 text-[10px] font-semibold rounded bg-canvas text-ink shadow-sm transition-all duration-150 cursor-pointer">
                    Show Changes
                  </button>
                  <button id="toggle-highlights" class="px-2.5 py-1 text-[10px] font-semibold rounded text-mute hover:text-ink transition-all duration-150 cursor-pointer">
                    AI tells
                  </button>
                </div>
              </div>

              <!-- Side-by-side or scroll text rendering -->
              <div class="max-h-[350px] overflow-y-auto pr-1 text-sm font-sans leading-relaxed text-ink space-y-3" id="humanized-text-container">
                <!-- Output injected here -->
              </div>

              <!-- Sentence Explorer popover box (inline floating options, hidden by default) -->
              <div id="sentence-explorer-card" class="hidden absolute left-4 right-4 bottom-16 bg-canvas border border-hairline-strong rounded-lg shadow-xl p-4 z-20 space-y-3 animate-fade-in">
                <div class="flex justify-between items-center border-b border-hairline pb-2">
                  <span class="text-xs font-semibold text-error flex items-center gap-1">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                    Linguistic Tell Resolved
                  </span>
                  <button id="sentence-explorer-close" class="text-mute hover:text-ink p-1 cursor-pointer">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  </button>
                </div>
                <div class="text-xs space-y-1">
                  <span class="text-mute">Original Phrase:</span>
                  <p id="sentence-explorer-original" class="text-body font-mono text-[11px] bg-canvas-soft-2 p-1.5 rounded border border-hairline"></p>
                </div>
                <div class="space-y-1.5">
                  <span class="text-xs font-semibold text-body">Select Alternative Version:</span>
                  <div class="space-y-1" id="sentence-explorer-options">
                    <!-- Alternative option items will be injected here -->
                  </div>
                </div>
              </div>

              <!-- Output Action Toolbar -->
              <div class="flex items-center justify-between border-t border-hairline pt-3 mt-4 text-xs font-mono">
                <span id="output-word-count" class="text-mute">Words: 0</span>
                
                <div class="flex items-center gap-2">
                  <button id="action-regenerate" class="flex items-center gap-1 px-3 py-1.5 text-xs text-body hover:text-ink hover:bg-canvas-soft-2 rounded border border-hairline transition-colors cursor-pointer" title="Regenerate rewriting">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.228 15" />
                    </svg>
                    Regen
                  </button>
                  <button id="action-download" class="flex items-center gap-1 px-3 py-1.5 text-xs text-body hover:text-ink hover:bg-canvas-soft-2 rounded border border-hairline transition-colors cursor-pointer" title="Download text as .txt">
                    Download
                  </button>
                  <button id="action-copy" class="button-primary-sm h-7 text-xs flex items-center justify-center gap-1 cursor-pointer">
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m-5 8h2m-2 4h2" />
                    </svg>
                    Copy Text
                  </button>
                </div>
              </div>
            </div>
          </ElectricBorder>

        </div>

      </div>

    </div>

  </div>

  <!-- Sliding History Drawer (Overlay/Sidebar effect) -->
  <div id="history-drawer" class="fixed inset-y-0 right-0 w-80 bg-canvas border-l border-hairline shadow-2xl z-50 transform translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
    <div class="p-4 border-b border-hairline flex items-center justify-between bg-canvas-soft-2">
      <h3 class="text-sm font-semibold text-ink flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Humanization Workspace
      </h3>
      <button id="history-drawer-close" class="p-1 text-body hover:text-ink cursor-pointer">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <!-- History items list -->
    <div id="history-items-container" class="flex-1 overflow-y-auto p-4 space-y-3">
      <!-- Injected list items -->
      <div class="text-center text-xs text-mute py-8">No history saved yet.</div>
    </div>
    
    <div class="p-4 border-t border-hairline bg-canvas-soft-2 flex justify-between">
      <button id="history-clear-all" class="text-xs text-mute hover:text-error transition-colors cursor-pointer">Clear Workspace</button>
      <span class="text-[10px] text-mute font-mono">Roll limit: 15 runs</span>
    </div>
  </div>
  
  <!-- Backdrop for History Drawer -->
  <div id="history-drawer-backdrop" class="fixed inset-0 bg-primary/20 backdrop-blur-xs z-40 hidden transition-opacity duration-300 opacity-0"></div>

  <!-- Custom Toast Notifications (Floating) -->
  <div id="toast-container" class="fixed bottom-5 right-5 z-50 flex flex-col gap-2"></div>
</section>

<script>
  // Dynamic application state
  const state: any = {
    mode: 'standard', // standard, advanced, academic, creative
    tab: 'humanizer', // humanizer, detector
    inputWords: 0,
    inputChars: 0,
    history: [],
    currentResponse: null,
    showDiff: true,
    showHighlights: false,
    user: null
  };

  const setProcessingState = (active: boolean) => {
    const container = document.getElementById('input-card-container');
    if (!container) return;
    if (active) {
      container.classList.add('active-processing-glow');
    } else {
      container.classList.remove('active-processing-glow');
    }
  };

  // Pre-defined NLP Replacement Thesaurus & Structure Shift rules
  const ROBOTIC_TELLS = [
    { regex: /\bdelve\b/gi, standard: 'dig', professional: 'analyze', academic: 'investigate', creative: 'plunge' },
    { regex: /\bdelve\s+into\b/gi, standard: 'look into', professional: 'explore', academic: 'examine', creative: 'plunge into' },
    { regex: /\bdelving\s+into\b/gi, standard: 'looking into', professional: 'exploring', academic: 'examining', creative: 'plunging into' },
    { regex: /\btestament\b/gi, standard: 'proof', professional: 'evidence', academic: 'demonstration', creative: 'tribute' },
    { regex: /\bfurthermore\b/gi, standard: 'also', professional: 'in addition', academic: 'additionally', creative: "what's more" },
    { regex: /\bmoreover\b/gi, standard: 'plus', professional: 'further', academic: 'consequently', creative: 'besides' },
    { regex: /\bin conclusion\b/gi, standard: 'overall', professional: 'in summary', academic: 'therefore', creative: 'to sum it up' },
    { regex: /\bnot only\s+([^.!?]+?)\s+but\s+also\s+([^.!?]+?)\b/gi, standard: 'both $1 and $2', professional: 'not just $1 but also $2', academic: 'both $1 and $2', creative: 'not just $1 but also $2' },
    { regex: /\badditionally\b/gi, standard: 'also', professional: 'furthermore', academic: 'consequently', creative: 'plus' },
    { regex: /\bconsequently\b/gi, standard: 'so', professional: 'as a result', academic: 'therefore', creative: 'so' },
    { regex: /\bpivotal\b/gi, standard: 'key', professional: 'crucial', academic: 'vital', creative: 'huge' },
    { regex: /\btapestry\b/gi, standard: 'mix', professional: 'framework', academic: 'integration', creative: 'blend' },
    { regex: /\bvital role\b/gi, standard: 'big part', professional: 'essential function', academic: 'primary role', creative: 'magic spark' },
    { regex: /\bin this digital age\b/gi, standard: 'today', professional: 'currently', academic: 'in modern times', creative: 'nowadays' },
    { regex: /\bin today's digital era\b/gi, standard: 'today', professional: 'currently', academic: 'contemporary environment', creative: 'now' },
    { regex: /\bit is worth noting that\b/gi, standard: 'keep in mind that', professional: 'note that', academic: 'importantly,', creative: 'remember that' },
    { regex: /\bit is essential to\b/gi, standard: 'you need to', professional: 'we must', academic: 'it is vital to', creative: "you've got to" },
    { regex: /\bon the other hand\b/gi, standard: 'but then', professional: 'however', academic: 'conversely', creative: 'mind you' },
    { regex: /\bin order to\b/gi, standard: 'to', professional: 'to', academic: 'to', creative: 'to' },
    { regex: /\bby utilizing\b/gi, standard: 'by using', professional: 'by using', academic: 'through', creative: 'using' },
    { regex: /\bwith regard to\b/gi, standard: 'about', professional: 'regarding', academic: 'concerning', creative: 'about' },
    { regex: /\bin terms of\b/gi, standard: 'for', professional: 'regarding', academic: 'concerning', creative: 'for' },
    { regex: /\ba wide range of\b/gi, standard: 'many', professional: 'various', academic: 'a diverse spectrum of', creative: 'a whole bunch of' },
    { regex: /\bat the end of the day\b/gi, standard: 'in the end', professional: 'ultimately', academic: 'conclusively', creative: 'when all is said and done' },
    { regex: /\bmake a decision\b/gi, standard: 'decide', professional: 'decide', academic: 'decide', creative: 'choose' },
    { regex: /\bprovide assistance\b/gi, standard: 'help', professional: 'assist', academic: 'aid', creative: 'lend a hand' },
    { regex: /\bconduct an analysis\b/gi, standard: 'study', professional: 'analyze', academic: 'investigate', creative: 'inspect' },
    { regex: /\bhas the capability to\b/gi, standard: 'can', professional: 'can', academic: 'is capable of', creative: 'is able to' },
    { regex: /\bplays a key role\b/gi, standard: 'helps a lot', professional: 'is essential', academic: 'contributes significantly', creative: 'makes a huge difference' },
    { regex: /\bgroundbreaking\b/gi, standard: 'new', professional: 'innovative', academic: 'novel', creative: 'fresh' },
    { regex: /\bdemystify\b/gi, standard: 'explain', professional: 'simplify', academic: 'clarify', creative: 'clear up' },
    { regex: /\bfoster\b/gi, standard: 'build', professional: 'encourage', academic: 'facilitate', creative: 'nurture' },
    { regex: /\bleverage\b/gi, standard: 'use', professional: 'use', academic: 'exploit', creative: 'harness' },
    { regex: /\butilize\b/gi, standard: 'use', professional: 'use', academic: 'employ', creative: 'use' },
    { regex: /\bcomprehensive\b/gi, standard: 'complete', professional: 'detailed', academic: 'thorough', creative: 'full' },
    { regex: /\brobust\b/gi, standard: 'strong', professional: 'reliable', academic: 'sound', creative: 'solid' },
    { regex: /\blandscape\b/gi, standard: 'field', professional: 'environment', academic: 'domain', creative: 'world' },
    { regex: /\bsynergy\b/gi, standard: 'unity', professional: 'collaboration', academic: 'cohesion', creative: 'blend' },
    { regex: /\bholistic\b/gi, standard: 'overall', professional: 'integrated', academic: 'comprehensive', creative: 'whole' },
    { regex: /\bbeacon\b/gi, standard: 'guide', professional: 'example', academic: 'reference', creative: 'light' },
    { regex: /\bunravel\b/gi, standard: 'solve', professional: 'resolve', academic: 'analyze', creative: 'untangle' },
    { regex: /\bnestled\b/gi, standard: 'placed', professional: 'located', academic: 'situated', creative: 'tucked' },
    { regex: /\bcatalyst\b/gi, standard: 'spark', professional: 'driver', academic: 'agent', creative: 'trigger' }
  ];

  // Contraction mappings for humanizing tone variance
  const CONTRACTIONS = [
    { regex: /\bit is\b/gi, replacement: "it's" },
    { regex: /\bdo not\b/gi, replacement: "don't" },
    { regex: /\bcannot\b/gi, replacement: "can't" },
    { regex: /\bcan not\b/gi, replacement: "can't" },
    { regex: /\bdoes not\b/gi, replacement: "doesn't" },
    { regex: /\bdid not\b/gi, replacement: "didn't" },
    { regex: /\bis not\b/gi, replacement: "isn't" },
    { regex: /\bare not\b/gi, replacement: "aren't" },
    { regex: /\bwas not\b/gi, replacement: "wasn't" },
    { regex: /\bwere not\b/gi, replacement: "weren't" },
    { regex: /\bhave not\b/gi, replacement: "haven't" },
    { regex: /\bhas not\b/gi, replacement: "hasn't" },
    { regex: /\bhad not\b/gi, replacement: "hadn't" },
    { regex: /\bwill not\b/gi, replacement: "won't" },
    { regex: /\bwould not\b/gi, replacement: "wouldn't" },
    { regex: /\bshould not\b/gi, replacement: "shouldn't" },
    { regex: /\bcould not\b/gi, replacement: "couldn't" },
    { regex: /\bwe are\b/gi, replacement: "we're" },
    { regex: /\bthey are\b/gi, replacement: "they're" },
    { regex: /\byou are\b/gi, replacement: "you're" },
    { regex: /\bwho is\b/gi, replacement: "who's" },
    { regex: /\bthere is\b/gi, replacement: "there's" }
  ];

  // Helper dictionary for structure modifiers based on tone
  const TONE_INTRODUCERS = {
    casual: ["Truth is,", "Actually,", "Think about it:", "Let's be real,", "To be fair,", "Honestly,"],
    friendly: ["You might notice that", "Here is the thing:", "Let's look at how", "Honestly, it's like", "As we all know,"],
    creative: ["Imagine this:", "For centuries, we believed", "A fascinating perspective shows", "What if", "Suddenly,"],
    professional: ["Specifically,", "Importantly,", "Indeed,", "To clarify,", "It is worth noting that"],
    academic: ["Consequently,", "Conclusively,", "Arguably,", "Evidently,", "Consistent with current research,"]
  };

