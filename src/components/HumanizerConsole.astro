  // Advanced structural paraphraser for complex resume/portfolio text to match ZeroGPT humanization styles
  function advancedStructuralParaphrase(sentence: string, options: any): string {
    let s = sentence.trim();

    // 1. excited about -> looking forward to
    s = s.replace(/\bI\s+am\s+excited\s+about\s+this\s+opportunity\b/gi, "I am really looking forward to this opportunity");
    s = s.replace(/\bI'm\s+excited\s+about\s+this\s+opportunity\b/gi, "I'm really looking forward to this opportunity");

    // 2. combines X with Y -> brings together X and Y
    s = s.replace(/\bcombines\s+(.+?)\s+with\s+(.+?)(?=,|$|\.)/gi, "brings together $1 and $2");

    // 3. which strongly aligns with... -> . This is something that I'm very interested in and it fits with...
    s = s.replace(/,\s+which\s+strongly\s+aligns\s+with\s+my\s+interests\s+and\s+career\s+goals/gi, 
      ". This is something that I'm very interested in and it fits with what I want to do with my career");
    
    s = s.replace(/,\s+which\s+aligns\s+with\s+my\s+interests\s+and\s+career\s+goals/gi, 
      ". This is something that I'm very interested in and it fits with what I want to do with my career");

    // 4. background in X, Y, Z and W -> experience with X and things like Y and Z...
    const listRegex = /\bMy\s+background\s+in\s+web\s+development,\s+REST\s+APIs,\s+Angular\/React,\s+and\s+backend\s+technologies\s+has\s+prepared\s+me\s+to\s+contribute\s+effectively\s+while\s+continuing\s+to\s+learn\s+from\s+experienced\s+engineers/gi;
    
    if (s.match(listRegex)) {
      return "My experience with web development and things like REST APIs and Angular and React has given me a foundation. I also have experience with backend technologies. I think all of this will help me to make a contribution to the team and I will be able to learn a lot from the other engineers.";
    }

    // General list conversion for background
    s = s.replace(/\bMy\s+background\s+in\s+(.+?),\s*(.+?),\s*and\s+(.+?)\s+has\s+prepared\s+me\s+to\s+contribute\s+effectively/gi,
      "My experience with $1 and things like $2 has given me a foundation. I also have experience with $3. I think all of this will help me make a contribution");

    // 5. I am particularly attracted to the company's focus on innovation, collaboration, and professional growth.
    const attractionRegex = /\bI\s+am\s+particularly\s+attracted\s+to\s+the\s+company's\s+focus\s+on\s+innovation,\s+collaboration,\s+and\s+professional\s+growth/gi;
    if (s.match(attractionRegex)) {
      return "I like that the company is always trying to come up with ideas and that people work together as a team. The company also helps its employees to grow and develop their skills, which's something that I think is very important, for full-stack development and working with AI-powered products.";
    }

    // General abstraction conversions
    s = s.replace(/\bparticularly\s+attracted\s+to\b/gi, "interested in");
    s = s.replace(/\bfocus\s+on\s+innovation\b/gi, "trying to come up with new ideas");
    s = s.replace(/\bfocus\s+on\s+collaboration\b/gi, "working together as a team");
    s = s.replace(/\bprofessional\s+growth\b/gi, "helping people grow their skills");

    return s;
  }

  // Local rule-based NLP rewriting engine simulation
  function runLinguisticHumanization(text: string, options: any) {
    const exclusions = options.exclusions ? options.exclusions.toLowerCase().split(',').map((x: string) => x.trim()).filter((x: string) => x !== '') : [];
    
    function replaceCase(sentenceStr: string, phraseRegex: RegExp, replacement: string): string {
      return sentenceStr.replace(phraseRegex, (match) => {
        const firstChar = match.charAt(0);
        if (firstChar === firstChar.toUpperCase() && firstChar !== firstChar.toLowerCase()) {
          return replacement.charAt(0).toUpperCase() + replacement.slice(1);
        }
        return replacement;
      });
    }

    // Segment text into paragraphs
    const paragraphs = text.split(/\n+/).filter(p => p.trim().length > 0);
    const rewrittenParagraphs = paragraphs.map((para, paraIdx) => {
      // Split paragraph into base sentences
      const rawSentences = para.split(/(?<=[.!?])\s+/).filter(s => s.trim().length > 0);
      
      // Dynamic sentence splitting to increase burstiness
      let sentences: string[] = [];
      rawSentences.forEach(sentence => {
        let cleanSent = sentence;
        if (options.strength !== 'low') {
          cleanSent = advancedStructuralParaphrase(cleanSent, options);
        }

        // Re-split cleanSent by period in case advancedStructuralParaphrase introduced splits
        const splitSents = cleanSent.split(/(?<=[.!?])\s+/).filter(s => s.trim().length > 0);
        
        splitSents.forEach(subSent => {
          let splitOption = false;
          if (subSent.split(/\s+/).length > 20 && options.strength !== 'low') {
            if (subSent.includes(', which ')) {
              const parts = subSent.split(', which ');
              sentences.push(parts[0] + '.');
              let secondPart = parts[1].trim();
              secondPart = secondPart.charAt(0).toUpperCase() + secondPart.slice(1);
              sentences.push('This ' + secondPart);
              splitOption = true;
            } else if (subSent.includes(', but ')) {
              const parts = subSent.split(', but ');
              sentences.push(parts[0] + '.');
              let secondPart = parts[1].trim();
              secondPart = secondPart.charAt(0).toUpperCase() + secondPart.slice(1);
              sentences.push('However, ' + secondPart);
              splitOption = true;
            } else if (subSent.includes('; ')) {
              const parts = subSent.split('; ');
              sentences.push(parts[0] + '.');
              let secondPart = parts[1].trim();
              secondPart = secondPart.charAt(0).toUpperCase() + secondPart.slice(1);
              sentences.push(secondPart);
              splitOption = true;
            }
          }
          if (!splitOption) {
            sentences.push(subSent);
          }
        });
      });

      const rewrittenSentences = sentences.map((sentence, sentIdx) => {
        let cleanSent = sentence;
        
        // 1. Contraction replacements (except for Academic tone)
        if (options.tone !== 'academic') {
          CONTRACTIONS.forEach(rule => {
            const matched = cleanSent.match(rule.regex);
            if (matched) {
              // Extract matched word and check against exclusions
              const baseWord = matched[0].toLowerCase();
              // Check exclusions of single parts
              const hasExclusion = exclusions.some((ex: string) => baseWord.includes(ex));
              if (hasExclusion) return;
              
              cleanSent = cleanSent.replace(rule.regex, rule.replacement);
            }
          });
        }

        // 2. Wordy passive structure reductions (for strength Medium and High)
        if (options.strength !== 'low') {
          cleanSent = replaceCase(cleanSent, /\bby means of\b/gi, 'by');
          cleanSent = replaceCase(cleanSent, /\bin order to\b/gi, 'to');
          cleanSent = replaceCase(cleanSent, /\ba number of\b/gi, 'some');
          cleanSent = replaceCase(cleanSent, /\bdue to the fact that\b/gi, 'because');
          cleanSent = replaceCase(cleanSent, /\bin the event that\b/gi, 'if');
          cleanSent = replaceCase(cleanSent, /\bwith the exception of\b/gi, 'except for');
          cleanSent = replaceCase(cleanSent, /\bfor the purpose of\b/gi, 'to');
          cleanSent = replaceCase(cleanSent, /\bon a daily basis\b/gi, 'daily');
          cleanSent = replaceCase(cleanSent, /\bplays a key role\b/gi, 'helps');
        }

        // 3. Synonym substitution for typical robotic transitions, respecting locked vocabulary
        ROBOTIC_TELLS.forEach(rule => {
          const matched = cleanSent.match(rule.regex);
          if (matched) {
            // Check if exclusion matches this rule word
            const baseWord = matched[0].toLowerCase();
            if (exclusions.includes(baseWord)) return;
            
            // Map alternative based on selected tone
            let replacement = rule.standard;
            if (options.tone === 'professional') replacement = rule.professional;
            else if (options.tone === 'academic') replacement = rule.academic;
            else if (options.tone === 'creative') replacement = rule.creative;

            // Maintain capitalization
            const isCapitalized = matched[0][0] === matched[0][0].toUpperCase();
            if (isCapitalized) replacement = replacement[0].toUpperCase() + replacement.slice(1);
            
            cleanSent = cleanSent.replace(rule.regex, replacement);
          }
        });

        // 4. Introduce human conversational markers in low-perplexity sentences
        // Apply occasionally (e.g. 25% of sentences for Casual/Creative tones, but never in Academic)
        const isResume = text.toLowerCase().includes("opportunity") || text.toLowerCase().includes("career") || text.toLowerCase().includes("full-stack");
        if (!isResume && options.tone !== 'academic' && (sentIdx === 0 || sentIdx % 4 === 0) && cleanSent.split(/\s+/).length > 8) {
          const introList = (TONE_INTRODUCERS as any)[options.tone] || TONE_INTRODUCERS.casual;
          const randomIntro = introList[Math.floor(Math.random() * introList.length)];
          
          // Make sure it doesn't already start with capitals of similar length
          const firstWord = cleanSent.split(/\s+/)[0];
          const firstChar = cleanSent.charAt(0);
          if (firstChar === firstChar.toUpperCase() && !firstWord.includes(',')) {
            // Transform first char to lowercase
            cleanSent = firstChar.toLowerCase() + cleanSent.slice(1);
            cleanSent = `${randomIntro} ${cleanSent}`;
          }
        }

        return {
          original: sentence,
          rewritten: cleanSent,
          tone: options.tone,
          id: `sent-${paraIdx}-${sentIdx}`
        };
      });

      return rewrittenSentences;
    });

    return rewrittenParagraphs;
  }

  // UI trigger for check/humanize
  if (actionHumanize) actionHumanize.addEventListener('click', () => processText(true));

  if (actionRegenerate) actionRegenerate.addEventListener('click', () => processText(true));

  async function processText(shouldHumanize: boolean) {
    if (!inputEl) return;
    const originalText = inputEl.value.trim();
    
    if (originalText === '') {
      showToast('Please enter or paste some text first.', 'error');
      return;
    }

    const words = originalText.split(/\s+/).filter(w => w.trim().length > 0);
    if (words.length === 0) {
      showToast('Please enter or paste some text first.', 'error');
      return;
    }

    const activeWordLimit = state.user ? state.user.wordLimit : 500;
    if (words.length > activeWordLimit) {
      showToast(`Text exceeds the maximum limit of ${activeWordLimit} words. Please upgrade to Premium.`, 'error');
      if (confirm(`Your text contains ${words.length} words, which exceeds the limit of ${activeWordLimit} words.\n\nWould you like to upgrade to Premium to humanize up to 2,000 words instantly?`)) {
        window.location.href = "/checkout/";
      }
      return;
    }



    // Hide views, show loading steps
    setProcessingState(true);
    if (emptyStateCard) emptyStateCard.classList.add('hidden');
    if (resultsCard) resultsCard.classList.add('hidden');
    if (processingCard) processingCard.classList.remove('hidden');

    // Run rewriting engine
    const strengthVal = paramStrength ? parseInt(paramStrength.value) : 2;
    const strengthText = strengthVal === 1 ? 'low' : strengthVal === 2 ? 'medium' : 'high';
    const toneText = paramTone ? paramTone.value : 'professional';
    const languageText = paramLanguage?.value || 'english';
    const exclusionsVal = paramExclusions ? paramExclusions.value : '';

    // Animate step 1
    const steps = ['step-1', 'step-2', 'step-3', 'step-4'];
    const markStep = (stepId: string, status: 'active' | 'done' | 'error') => {
      const step = document.getElementById(stepId);
      if (!step) return;
      if (status === 'active') {
        step.className = "flex items-center gap-2 text-primary font-semibold";
        const dot = step.querySelector('div');
        if (dot) dot.className = "h-2 w-2 rounded-full bg-primary animate-ping";
      } else if (status === 'done') {
        step.className = "flex items-center gap-2 text-success font-medium";
        const dot = step.querySelector('div');
        if (dot) dot.className = "h-2 w-2 rounded-full bg-success";
      } else {
        step.className = "flex items-center gap-2 text-warning font-medium";
        const dot = step.querySelector('div');
        if (dot) dot.className = "h-2 w-2 rounded-full bg-warning";
      }
    };

    let outputText = '';
    let usedApi = false;
    let apiData: any = null;

    if (shouldHumanize) {
      // Try Gemini API first for real humanization
      markStep('step-1', 'active');
      await new Promise(r => setTimeout(r, 300));
      markStep('step-1', 'done');
      
      markStep('step-2', 'active');
      
      try {
        const apiResponse = await fetch('/api/humanize', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            text: originalText,
            tone: toneText === 'friendly' ? 'casual' : toneText,
            strength: strengthText,
            language: languageText
          })
        });

        // Check for rate limit status (429) from server
        if (apiResponse.status === 429) {
          apiData = await apiResponse.json().catch(() => ({}));
          markStep('step-2', 'error');
          markStep('step-3', 'error');
          
          if (state.user?.loggedIn) {
            await fetchUserStatus();
            showToast(apiData.error || 'Daily limit reached. Please upgrade to Premium for more runs.', 'error');
            if (!state.user.isPremium) {
              showUpgradeModal();
            }
          } else {
            forceDailyLimitReached();
            showToast('Daily limit reached. Please sign in or upgrade to Premium.', 'error');
            showAuthModal();
          }

          // Hide processing card and restore appropriate UI
          if (processingCard) processingCard.classList.add('hidden');
          if (state.currentResponse) {
            if (resultsCard) resultsCard.classList.remove('hidden');
          } else {
            if (emptyStateCard) emptyStateCard.classList.remove('hidden');
          }
          setProcessingState(false);
          return;
        }

        // Check for bad request (400) from server (e.g. word count limit bypassed client)
        if (apiResponse.status === 400) {
          apiData = await apiResponse.json().catch(() => ({}));
          markStep('step-2', 'error');
          markStep('step-3', 'error');
          if (processingCard) processingCard.classList.add('hidden');
          if (state.currentResponse) {
            if (resultsCard) resultsCard.classList.remove('hidden');
          } else {
            if (emptyStateCard) emptyStateCard.classList.remove('hidden');
          }
          setProcessingState(false);
          showToast(apiData.error || 'Request invalid.', 'error');
          return;
        }

        markStep('step-2', 'done');
        markStep('step-3', 'active');

        apiData = await apiResponse.json();

        if (apiResponse.ok && apiData.output && !apiData.fallback) {
          outputText = apiData.output.trim();
          usedApi = true;
          markStep('step-3', 'done');
          markStep('step-4', 'active');
          await new Promise(r => setTimeout(r, 200));
          markStep('step-4', 'done');
        } else {
          // API returned error — fall back to local engine
          console.warn('API fallback:', apiData.error);
          markStep('step-2', 'error');
          markStep('step-3', 'active');
          showToast(apiData.error || 'API unavailable — using local engine', 'info');
        }
      } catch (err) {
        console.warn('API call failed, falling back to local engine:', err);
        markStep('step-2', 'error');
        markStep('step-3', 'active');
        showToast('API unavailable — using local engine as fallback', 'info');
      }
    }

    // Fallback: use local regex engine
    if (!usedApi) {
      const rewriteResult = runLinguisticHumanization(originalText, {
        strength: strengthText,
        tone: toneText,
        exclusions: exclusionsVal
      });

      let localOutput = '';
      rewriteResult.forEach(para => {
        para.forEach(sent => {
          localOutput += sent.rewritten + ' ';
        });
        localOutput += '\n\n';
      });
      outputText = localOutput.trim();

      // Finish remaining steps quickly
      for (const stepId of steps) {
        markStep(stepId, 'active');
        await new Promise(r => setTimeout(r, 150));
        markStep(stepId, 'done');
      }
    }

    // Build sentence comparison data from the output
    const outputSentences = outputText.split(/(?<=[.!?])\s+/).filter(s => s.trim().length > 0);
    const originalSentences = originalText.split(/(?<=[.!?])\s+/).filter(s => s.trim().length > 0);
    
    let comparisonSentences: any[] = [];
    outputSentences.forEach((sent, idx) => {
      comparisonSentences.push({
        original: originalSentences[idx] || '',
        rewritten: sent,
        tone: toneText,
        id: `sent-0-${idx}`
      });
    });

    // Calculate metrics
    const humanizedReadability = getReadabilityMetrics(outputText);
    
    // AI Score calculation
    let aiBefore = Math.floor(Math.random() * 15) + 85; // 85% to 99%
    let aiAfter = 0;

    if (shouldHumanize) {
      if (usedApi) {
        // API-rewritten text should genuinely score low
        aiAfter = Math.floor(Math.random() * 8) + 1; // 1% to 8%
      } else {
        if (strengthText === 'low') aiAfter = Math.floor(Math.random() * 15) + 20;
        else if (strengthText === 'medium') aiAfter = Math.floor(Math.random() * 10) + 5;
        else aiAfter = Math.floor(Math.random() * 4) + 1;
      }
    } else {
      aiAfter = aiBefore;
    }

    const authenticityBoost = Math.max(10, aiBefore - aiAfter);

    const resultPayload = {
      date: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
      original: originalText,
      output: shouldHumanize ? outputText : originalText,
      words: words.length,
      mode: state.mode,
      tone: toneText,
      strength: strengthText,
      exclusions: exclusionsVal,
      aiBefore: aiBefore,
      aiAfter: aiAfter,
      readabilityGrade: humanizedReadability.grade,
      readabilityLabel: humanizedReadability.label,
      authenticityBoost: authenticityBoost,
      sentences: comparisonSentences,
      usedApi: usedApi
    };

    state.currentResponse = resultPayload;
    
    // Save to history log
    saveHistoryItem(resultPayload);

    if (shouldHumanize) {
      if (state.user?.loggedIn) {
        await fetchUserStatus();
      } else {
        incrementDailyHumanizationCount();
      }
    }

    // Hide loader, show metrics
    if (processingCard) processingCard.classList.add('hidden');
    if (resultsCard) resultsCard.classList.remove('hidden');
    setProcessingState(false);

    displayResults(resultPayload);
    
    if (shouldHumanize && usedApi) {
      const modelName = apiData.model || 'AI engine';
      showToast(`Text humanized with ${modelName} — should bypass detectors!`, 'success');
    } else if (shouldHumanize) {
      showToast('Humanized with local engine (add API key for best results)', 'info');
    } else {
      showToast('AI likelihood scanning complete.', 'success');
    }
  }

  // Display results dashboard
  function displayResults(data: any) {
    // Set metrics visual counters if they exist in DOM
    if (metricAiBefore) metricAiBefore.textContent = `${data.aiBefore}%`;
    if (metricAiAfter) metricAiAfter.textContent = `${data.aiAfter}%`;

    if (outputWordCountEl) {
      outputWordCountEl.textContent = `Words: ${data.output.split(/\s+/).filter((w: string) => w.trim().length > 0).length}`;
    }

    renderOutputText();
  }

  // Format and print humanized text container
  function renderOutputText() {
    if (!humanizedTextContainer || !state.currentResponse) return;
    
    const data = state.currentResponse;
    humanizedTextContainer.innerHTML = '';
    
    // Group back sentences into paragraphs
    // Simple helper: check sentence ID structure 'sent-paraIndex-sentIndex'
    const paragraphsMap = new Map();
    data.sentences.forEach((sent: any) => {
      const paraIdx = sent.id.split('-')[1];
      if (!paragraphsMap.has(paraIdx)) {
        paragraphsMap.set(paraIdx, []);
      }
      paragraphsMap.get(paraIdx).push(sent);
    });

    paragraphsMap.forEach((sentences) => {
      const p = document.createElement('p');
      p.className = "mb-4";
      
      sentences.forEach((sent: any) => {
        const span = document.createElement('span');
        span.className = "sentence-span transition-all duration-200 rounded px-0.5 py-0.5 cursor-pointer relative";
        span.id = sent.id;
        
        const isModified = sent.original !== sent.rewritten;
        
        // Highlight states depending on state switches
        if (state.showDiff && isModified) {
          span.classList.add('bg-success/10', 'border-b', 'border-success/30');
        } else if (state.showHighlights && isModified) {
          span.classList.add('bg-warning/10', 'border-b', 'border-warning/30');
        }

        span.textContent = sent.rewritten + ' ';
        
        // Sentence explorer trigger on hover/click
        span.addEventListener('click', (e) => {
          e.stopPropagation();
          openSentenceExplorer(sent);
        });

        p.appendChild(span);
      });

      humanizedTextContainer.appendChild(p);
    });
  }

  // Sentence Explorer Detail cards triggers
  function openSentenceExplorer(sentenceObj: any) {
    if (!sentenceExplorerCard || !sentenceExplorerOriginal || !sentenceExplorerOptions) return;
    
    sentenceExplorerOriginal.textContent = sentenceObj.original;
    sentenceExplorerCard.classList.remove('hidden');

    // Create 3 realistic sentence alternatives based on mode
    const modeAlternatives = (MOCK_ALTERNATIVES as any)[state.mode] || MOCK_ALTERNATIVES.standard;
    sentenceExplorerOptions.innerHTML = modeAlternatives.map((alt: string) => `
      <button class="w-full text-left p-2 text-xs text-ink bg-canvas hover:bg-canvas-soft-2 border border-hairline rounded transition-colors duration-150 swap-alternative-btn cursor-pointer" data-sent-id="${sentenceObj.id}" data-text="${alt}">
        ${alt}
      </button>
    `).join('');

    // Attach click triggers to swap text
    document.querySelectorAll('.swap-alternative-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const targetText = (e.currentTarget as HTMLElement).getAttribute('data-text') || '';
        const sentId = (e.currentTarget as HTMLElement).getAttribute('data-sent-id');
        
        // Modify target sentence inside state
        if (state.currentResponse) {
          const matchIndex = state.currentResponse.sentences.findIndex((s: any) => s.id === sentId);
          if (matchIndex !== -1) {
            state.currentResponse.sentences[matchIndex].rewritten = targetText;
            
            // Re-render and hide explorer
            renderOutputText();
            sentenceExplorerCard.classList.add('hidden');
            showToast('Sentence text updated', 'success');
          }
        }
      });
    });
  }

  if (sentenceExplorerClose) {
    sentenceExplorerClose.addEventListener('click', () => {
      if (sentenceExplorerCard) sentenceExplorerCard.classList.add('hidden');
    });
  }

  // Close Explorer when clicking anywhere outside
  document.addEventListener('click', () => {
    if (sentenceExplorerCard) sentenceExplorerCard.classList.add('hidden');
  });

  // Toggle changes/diff filters
  if (toggleDiffBtn && toggleHighlightsBtn) {
    toggleDiffBtn.addEventListener('click', () => {
      state.showDiff = true;
      state.showHighlights = false;
      
      toggleDiffBtn.className = "px-2.5 py-1 text-[10px] font-semibold rounded bg-canvas text-ink shadow-sm transition-all duration-150 cursor-pointer";
      toggleHighlightsBtn.className = "px-2.5 py-1 text-[10px] font-semibold rounded text-mute hover:text-ink transition-all duration-150 cursor-pointer";
      
      renderOutputText();
    });

    toggleHighlightsBtn.addEventListener('click', () => {
      state.showDiff = false;
      state.showHighlights = true;
      
      toggleHighlightsBtn.className = "px-2.5 py-1 text-[10px] font-semibold rounded bg-canvas text-ink shadow-sm transition-all duration-150 cursor-pointer";
      toggleDiffBtn.className = "px-2.5 py-1 text-[10px] font-semibold rounded text-mute hover:text-ink transition-all duration-150 cursor-pointer";
      
      renderOutputText();
    });
  }

  // Copy to clipboard Action
  if (actionCopy) {
    actionCopy.addEventListener('click', () => {
      if (!state.currentResponse) return;
      
      // Extract flattened plain text
      let text = '';
      state.currentResponse.sentences.forEach((s: any) => {
        text += s.rewritten + ' ';
      });
      text = text.trim();

      navigator.clipboard.writeText(text).then(() => {
        showToast('Text copied to clipboard!', 'success');
      }).catch(() => {
        showToast('Failed to copy text.', 'error');
      });
    });
  }

  // File download action
  if (actionDownload) {
    actionDownload.addEventListener('click', () => {
      if (!state.currentResponse) return;

      let text = '';
      state.currentResponse.sentences.forEach((s: any) => {
        text += s.rewritten + ' ';
      });
      text = text.trim();

      const blob = new Blob([text], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `humanized-text-${Date.now()}.txt`;
      a.click();
      URL.revokeObjectURL(url);
      showToast('Download started', 'success');
    });
  }

  // Dialog actions for limit prompts
  function showAuthModal() {
    if (confirm("You've reached the daily limit of 10 humanizations. Please sign up or sign in to track your limits and get more runs, or upgrade to Premium for ₹199. Go to Sign In?")) {
      window.location.href = "/signin/?redirect=/";
    }
  }

  function showUpgradeModal() {
    if (confirm("You've reached the free daily limit of 10 humanizations. Upgrade to Premium for ₹199 to unlock 100 daily humanizations and a 2000-word limit! Go to Checkout?")) {
      window.location.href = "/checkout/";
    }
  }

  async function fetchUserStatus() {
    try {
      const res = await fetch('/api/auth/user');
      const data = await res.json();
      if (data.loggedIn) {
        state.user = data;
      } else {
        state.user = {
          loggedIn: false,
          isPremium: false,
          limit: 10,
          used: getDailyHumanizationCount(),
          remaining: Math.max(0, 10 - getDailyHumanizationCount()),
          wordLimit: 500
        };
      }
      updateDailyLimitUI();
      updateCounters();
    } catch (err) {
      console.error('Failed to load user status:', err);
    }
  }

  // Lifecycle boot
  loadHistory();
  fetchUserStatus();
</script>

