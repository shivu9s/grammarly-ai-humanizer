  // Syllables estimation helper
  function estimateSyllables(word: string): number {
    word = word.toLowerCase().trim();
    if (word.length <= 3) return 1;
    word = word.replace(/(?:es|ed|e)$/, '');
    word = word.replace(/^y/, '');
    const vowels = word.match(/[aeiouy]{1,2}/g);
    return vowels ? vowels.length : 1;
  }

  // Flesch Grade Reading Index Formula
  function getReadabilityMetrics(text: string) {
    const sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);
    const words = text.split(/\s+/).filter(w => w.trim().length > 0);
    if (words.length === 0 || sentences.length === 0) return { grade: 8, label: 'Easy' };

    let totalSyllables = 0;
    words.forEach(w => {
      totalSyllables += estimateSyllables(w);
    });

    const wordsPerSentence = words.length / sentences.length;
    const syllablesPerWord = totalSyllables / words.length;

    // Flesch Grade Index
    const grade = Math.round(0.39 * wordsPerSentence + 11.8 * syllablesPerWord - 15.59);
    const clampedGrade = Math.max(1, Math.min(18, grade));

    let label = 'Moderate';
    if (clampedGrade <= 6) label = 'Very Easy';
    else if (clampedGrade <= 9) label = 'Easy';
    else if (clampedGrade <= 12) label = 'Moderate';
    else if (clampedGrade <= 15) label = 'Advanced';
    else label = 'Academic';

    return {
      grade: clampedGrade,
      label: label
    };
  }

