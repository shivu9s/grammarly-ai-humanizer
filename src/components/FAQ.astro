  ]
}
</script>

<script>
  // Client-side search functionality
  const searchInput = document.getElementById('faq-search') as HTMLInputElement;
  const faqItems = document.querySelectorAll('.faq-item') as NodeListOf<HTMLDetailsElement>;

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      const query = target.value.toLowerCase().trim();

      faqItems.forEach(item => {
        const questionElement = item.querySelector('.faq-question');
        const answerElement = item.querySelector('.faq-answer');
        
        if (questionElement && answerElement) {
          const questionText = questionElement.textContent?.toLowerCase() || '';
          const answerText = answerElement.textContent?.toLowerCase() || '';

          if (questionText.includes(query) || answerText.includes(query)) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
            // Also close it so it's not open if user clears search later
            item.removeAttribute('open');
          }
        }
      });
    });
  }
</script>

<style>
  /* Remove default markers on summaries */
  summary::-webkit-details-marker {
    display: none;
  }
</style>
