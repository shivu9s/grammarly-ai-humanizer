---
// Hero.astro
---

<section class="relative w-full overflow-hidden bg-canvas py-20 lg:py-32 border-b border-hairline transition-colors duration-200">
  <!-- Mesh Gradient Background -->
  <div class="mesh-backdrop"></div>

  <!-- Content Container -->
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center z-10">
    
    <!-- Announcement Banner -->
    <div class="inline-flex items-center gap-2 rounded-full border border-link-bg-soft bg-link-bg-soft/20 dark:bg-link-bg-soft/10 px-3 py-1 text-xs text-link mb-8 transition-transform hover:scale-[1.02] duration-150">
      <span class="font-mono uppercase font-semibold tracking-wider text-[10px] bg-link/10 dark:bg-link/20 px-2 py-0.5 rounded-full">New</span>
      <span class="font-sans font-medium">Bypass GPTZero, Turnitin & ZeroGPT with 99% success rate</span>
    </div>

    <!-- Main Headline -->
    <h1 class="mx-auto max-w-4xl font-sans text-4xl font-bold tracking-[-1.5px] sm:text-5xl md:text-6xl text-ink leading-tight sm:leading-none mb-6">
      Transform AI text into natural, <span class="bg-gradient-to-r from-gradient-develop-start via-gradient-preview-start to-gradient-ship-end bg-clip-text text-transparent">human-like writing</span>.
    </h1>

    <!-- Lead Paragraph -->
    <p class="mx-auto max-w-2xl text-body text-base sm:text-lg md:text-xl font-normal leading-relaxed mb-10">
      Say goodbye to robotic phrasing and AI detection flags. Rewrite essays, emails, blog posts, and copy instantly using advanced natural language structuring that preserves meaning.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#console" class="button-primary w-full sm:w-auto h-12 flex items-center justify-center font-semibold text-base shadow-sm hover:shadow-md">
        Start Humanizing Now
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
      <a href="#features" class="button-secondary w-full sm:w-auto h-12 flex items-center justify-center font-medium text-base">
        How It Works
      </a>
    </div>

    <!-- Trusted By / Features Preview Small List -->
    <div class="mt-20 border-t border-hairline/60 pt-8 max-w-5xl mx-auto">
      <p class="text-xs font-mono uppercase tracking-widest text-mute mb-6">Engineered to bypass major detection models</p>
      
      <!-- Competitor / Detector list logos (stark, clean) -->
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-16 opacity-60 dark:opacity-85 grayscale hover:grayscale-0 transition-all duration-300">
        <!-- GPTZero Logo text -->
        <span class="font-sans font-semibold text-lg text-ink select-none tracking-tight">GPT<span class="text-mute font-normal">Zero</span></span>
        
        <!-- Turnitin Logo text -->
        <span class="font-sans font-bold text-lg text-ink select-none tracking-tighter">turnitin</span>
        
        <!-- Copyleaks Logo text -->
        <span class="font-mono font-medium text-base text-ink select-none tracking-wide">COPYLEAKS</span>
        
        <!-- ZeroGPT Logo text -->
        <span class="font-sans font-extrabold text-lg text-ink select-none tracking-normal">Zero<span class="text-link font-normal">GPT</span></span>

        <!-- Originality AI Logo text -->
        <span class="font-sans font-semibold text-base text-ink select-none tracking-widest">ORIGINALITY.AI</span>
      </div>
    </div>
  </div>
</section>
