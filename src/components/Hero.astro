---
// Hero.astro
---

<section class="relative w-full overflow-hidden pt-36 pb-20 lg:pt-44 lg:pb-32 border-b border-hairline transition-colors duration-200">
  <!-- Mesh Gradient Background -->
  <div class="mesh-backdrop"></div>
  
  <!-- Ambient background glow blobs -->
  <div class="ambient-glow-wrapper">
    <div class="ambient-blob blob-primary"></div>
    <div class="ambient-blob blob-secondary"></div>
    <div class="ambient-blob blob-tertiary"></div>
  </div>

  <!-- Content Container -->
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center z-10">
    
    <!-- Main Headline -->
    <h1 class="mx-auto max-w-4xl font-sans text-4xl font-bold tracking-[-1.5px] sm:text-5xl md:text-6xl text-ink leading-tight sm:leading-none mb-6 animate-fade-up delay-100">
      Transform AI text into natural, <span class="bg-gradient-to-r from-gradient-develop-start via-gradient-preview-start to-gradient-ship-end bg-clip-text text-transparent">human-like writing</span>.
    </h1>

    <!-- Lead Paragraph -->
    <p class="mx-auto max-w-2xl text-body text-base sm:text-lg md:text-xl font-normal leading-relaxed mb-10 animate-fade-up delay-200">
      Say goodbye to robotic phrasing and AI detection flags. Rewrite essays, emails, blog posts, and copy instantly using advanced natural language structuring that preserves meaning.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up delay-300">
      <a href="#console" class="button-primary w-full sm:w-auto h-12 flex items-center justify-center font-semibold text-base shadow-sm hover:shadow-md shimmer-btn">
        Start Humanizing Now
        <svg class="ml-2 h-4 w-4 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
      <a href="#features" class="button-secondary w-full sm:w-auto h-12 flex items-center justify-center font-medium text-base hover:scale-[1.02] duration-150">
        How It Works
      </a>
    </div>

    <!-- Trusted By / Features Preview Small List -->
    <div class="mt-20 border-t border-hairline/60 pt-8 max-w-5xl mx-auto animate-fade-up delay-500">
      <p class="text-xs font-mono uppercase tracking-widest text-mute mb-6">Engineered to bypass major detection models</p>
      
      <!-- Infinite Marquee Container with fade gradient mask -->
      <div class="relative w-full overflow-hidden mask-fade-sides py-2">
        <div class="flex w-max animate-marquee whitespace-nowrap">
          <!-- First set of logos -->
          <div class="flex items-center gap-16 md:gap-24 opacity-60 dark:opacity-85 grayscale hover:grayscale-0 transition-all duration-300 pr-16 md:pr-24">
            <!-- GPTZero Logo text -->
            <span class="font-sans font-semibold text-lg text-ink select-none tracking-tight">GPT<span class="text-mute font-normal">Zero</span></span>
            
            <!-- Turnitin Logo text -->
            <span class="font-sans font-bold text-lg text-ink select-none tracking-tighter">turnitin</span>
            
            <!-- Copyleaks Logo text -->
            <span class="font-mono font-medium text-base text-ink select-none tracking-wide">COPYLEAKS</span>
            
            <!-- ZeroGPT Logo text -->
            <span class="font-sans font-extrabold text-lg text-ink select-none tracking-normal">Zero<span class="text-link font-normal">GPT</span></span>

            <!-- Originality AI Logo text -->
            <span class="font-sans font-semibold text-base text-ink select-none tracking-widest">ORIGINALITY.AI</span>
          </div>

          <!-- Second identical set of logos for seamless loop -->
          <div class="flex items-center gap-16 md:gap-24 opacity-60 dark:opacity-85 grayscale hover:grayscale-0 transition-all duration-300 pr-16 md:pr-24" aria-hidden="true">
            <!-- GPTZero Logo text -->
            <span class="font-sans font-semibold text-lg text-ink select-none tracking-tight">GPT<span class="text-mute font-normal">Zero</span></span>
            
            <!-- Turnitin Logo text -->
            <span class="font-sans font-bold text-lg text-ink select-none tracking-tighter">turnitin</span>
            
            <!-- Copyleaks Logo text -->
            <span class="font-mono font-medium text-base text-ink select-none tracking-wide">COPYLEAKS</span>
            
            <!-- ZeroGPT Logo text -->
            <span class="font-sans font-extrabold text-lg text-ink select-none tracking-normal">Zero<span class="text-link font-normal">GPT</span></span>

            <!-- Originality AI Logo text -->
            <span class="font-sans font-semibold text-base text-ink select-none tracking-widest">ORIGINALITY.AI</span>
          </div>
        </div>
      </div>
    </div>

<style>
  .mask-fade-sides {
    mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
  }

  .animate-marquee {
    animation: marquee 25s linear infinite;
  }

  .animate-marquee:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% {
      transform: translate3d(0, 0, 0);
    }
    100% {
      transform: translate3d(-50%, 0, 0);
    }
  }
</style>
  </div>
</section>
