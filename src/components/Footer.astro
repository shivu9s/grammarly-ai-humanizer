---
// Footer.astro
---

<footer class="w-full bg-transparent border-t border-hairline py-16 transition-colors duration-200">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 border-b border-hairline pb-12 mb-12">
      
      <!-- Brand column -->
      <div class="col-span-2 space-y-4">
        <a href="/" class="flex items-center gap-2 group">
          <img src="/logo.png" alt="AI Humanizer Logo" class="h-16 w-auto object-contain rounded-md" />
        </a>
        <p class="text-xs text-body max-w-xs leading-relaxed">
          The developer-first AI humanization engine. Elevating pacing, perplexity, and syntax to bypass flags and enhance writing quality.
        </p>
      </div>

      <!-- Links Column 1: Product -->
      <div class="space-y-3">
        <h4 class="text-[10px] font-mono uppercase tracking-wider text-mute font-semibold">Product</h4>
        <ul class="space-y-2 text-xs">
          <li><a href="#console" class="text-body hover:text-ink transition-colors">AI Humanizer</a></li>
          <li><a href="#features" class="text-body hover:text-ink transition-colors">How it Works</a></li>
          <li><a href="#faqs" class="text-body hover:text-ink transition-colors">FAQs</a></li>
        </ul>
      </div>

      <!-- Links Column 2: Resources -->
      <div class="space-y-3">
        <h4 class="text-[10px] font-mono uppercase tracking-wider text-mute font-semibold">Resources</h4>
        <ul class="space-y-2 text-xs">
          <li><a href="https://docs.astro.build" target="_blank" class="text-body hover:text-ink transition-colors">Documentation</a></li>
          <li><a href="#features" class="text-body hover:text-ink transition-colors">API References</a></li>
          <li><a href="/about-us/" class="text-body hover:text-ink transition-colors">About Us</a></li>
          <li><a href="/contact-us/" class="text-body hover:text-ink transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Links Column 3: Legal -->
      <div class="space-y-3">
        <h4 class="text-[10px] font-mono uppercase tracking-wider text-mute font-semibold">Legal</h4>
        <ul class="space-y-2 text-xs">
          <li><a href="/privacy-policy/" class="text-body hover:text-ink transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-conditions/" class="text-body hover:text-ink transition-colors">Terms & Conditions</a></li>
          <li><a href="#" class="text-body hover:text-ink transition-colors">Cookie Settings</a></li>
          <li><a href="#" class="text-body hover:text-ink transition-colors">DMCA Policy</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom copyright / meta -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs font-mono text-mute">
      <p>© 2026 Grammarly AI Humanizer, Inc. All rights reserved.</p>
    </div>
  </div>
</footer>
