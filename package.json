{
  "name": "grammarly-ai-humanizer",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "astro build && wrangler deploy --config dist/server/wrangler.json",
    "preview:wrangler": "astro build && wrangler dev --config dist/server/wrangler.json",
    "typecheck": "astro check && tsc --noEmit",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "@astrojs/node": "^11.0.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  }
}
